{
  "hub-discovery": {
    "source": "links",
    "render": false,
    "depth": 2,
    "limit": 100,
    "formats": ["markdown"],
    "options": {
      "includeExternalLinks": true,
      "includeSubdomains": false,
      "includePatterns": [
        "https://*.colorado.gov/**",
        "https://*.state.co.us/**",
        "https://*.co.us/**"
      ],
      "excludePatterns": [
        "**/news/**",
        "**/press/**",
        "**/blog/**",
        "**/*.pdf",
        "**/*.jpg",
        "**/*.png",
        "**/search/**",
        "**/privacy/**",
        "**/terms/**",
        "**/accessibility/**"
      ]
    }
  },
  "domain-freshness": {
    "source": "all",
    "render": false,
    "depth": 3,
    "limit": 100,
    "formats": ["markdown"],
    "options": {
      "includeExternalLinks": false,
      "includeSubdomains": false,
      "excludePatterns": [
        "**/news/**",
        "**/press/**",
        "**/blog/**",
        "**/*.pdf",
        "**/*.doc*",
        "**/*.xls*",
        "**/privacy/**",
        "**/terms/**",
        "**/accessibility/**"
      ]
    }
  },
  "rendered-retry": {
    "source": "links",
    "render": true,
    "depth": 2,
    "limit": 25,
    "formats": ["markdown"],
    "options": {
      "includeExternalLinks": false,
      "includeSubdomains": false
    }
  },
  "recovery": {
    "source": "all",
    "render": false,
    "depth": 2,
    "limit": 50,
    "formats": ["markdown"],
    "options": {
      "includeExternalLinks": false,
      "includeSubdomains": false,
      "excludePatterns": [
        "**/news/**",
        "**/press/**",
        "**/blog/**",
        "**/*.pdf",
        "**/*.doc*",
        "**/*.xls*"
      ]
    }
  }
}
